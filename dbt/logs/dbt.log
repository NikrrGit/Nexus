,'job_run_results','CREATE VIEW','success','model',0.4194371700286865,'2026-04-12T19:26:29.008617Z','2026-04-12T19:26:29.341855Z','2026-04-12T19:26:28.940115Z','2026-04-12T19:26:29.006175Z',-1,
